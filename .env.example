# Required for the Playground chat API (lesson pages).
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional. Zapier webhook URL for the course completion certificate form.
# When set, POST /api/certificate sends { nome, email, idioma, consentimento_noticia } to this URL.
# Leave unset for local dev (certificate still works; no webhook called).
# ZAPIER_CERTIFICATE_WEBHOOK_URL=
